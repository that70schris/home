
<xg>
    <panel_widget height="120" id="1" left="0" top="0" width="200">
        <bg_color>0xFF212121</bg_color>
        <radio_widget class="P35WidgetColorSwatch" height="84" id="colr" left="6" top="30" width="188">
            <anchor_pos bottom="6" left="6" right="6" top="30"/>
            <bg_color>0xFF000000</bg_color>
        </radio_widget>
        <text_edit_widget height="20" id="lblb" left="50" top="6" width="144">
            <anchor_pos left="50" right="6" top="6"/>
            <bg_color>0xFF000000</bg_color>
            <border_color>0xFF808080</border_color>
            <corner_radius>2</corner_radius>
            <text>
                <label>Enter new stomp label</label>
                <font name="Inter" size="14"/>
                <text_color>0xFF808080</text_color>
            </text>
            <text_limit>24</text_limit>
            <activate_on_focus>yes</activate_on_focus>
        </text_edit_widget>
        <text_widget height="21" id="1" left="6" top="6" width="47">
            <anchor_pos left="6" top="6"/>
            <bg_color>0x00000000</bg_color>
            <text>
                <label>Label:</label>
                <font name="Inter" size="14"/>
                <align vert="middle"/>
                <text_color>0xFF808080</text_color>
            </text>
        </text_widget>
    </panel_widget>
</xg>