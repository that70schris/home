
<xg>
    <panel_widget height="240" id="1" left="0" top="0" width="480">
        <bg_color>0xFF141414</bg_color>
        <text_widget height="32" id="txth" left="50" top="16" width="380">
            <anchor_pos left="50" right="50" top="16"/>
            <bg_color>0x00000000</bg_color>
            <text>
                <label>PIN Required</label>
                <font name="Inter Display" size="18" weight="semibold"/>
                <align horz="center" vert="middle"/>
                <text_color>0xFFFFFFFF</text_color>
            </text>
        </text_widget>
        <text_widget height="50" id="txts" left="53" top="53" width="374">
            <relative_pos x="50"/>
            <bg_color>0x00000000</bg_color>
            <text>
                <label>Enter the required PIN code below. View or set the code on the device by navigating to Global Settings &gt; Preferences.</label>
                <font name="Inter Display" size="14"/>
                <align horz="center"/>
                <multiline>yes</multiline>
                <text_color>0xFFA6A6A6</text_color>
            </text>
        </text_widget>
        <pushbutton_widget height="32" id="cncl" left="20" top="188" width="92">
            <anchor_pos bottom="20" left="20"/>
            <bg_color>0xFF4A4A4A</bg_color>
            <corner_radius>6</corner_radius>
            <icon_placement spacing="4">-1</icon_placement>
            <text>
                <label>Cancel</label>
                <font name="Inter Display" size="14"/>
                <text_color>0xCCFFFFFF</text_color>
            </text>
            <active_state>
                <bg_color>0xFF3D3D3D</bg_color>
                <fg_color>0xFFFFFFFF</fg_color>
                <offset y="1"/>
            </active_state>
            <hilite_state>
                <bg_color>0xFF5C5C5C</bg_color>
                <fg_color>0xFFFFFFFF</fg_color>
            </hilite_state>
        </pushbutton_widget>
        <pushbutton_widget height="32" id="cnfm" left="368" top="188" width="92">
            <anchor_pos bottom="20" right="20"/>
            <bg_color>0xFF0A700A</bg_color>
            <corner_radius>6</corner_radius>
            <icon_placement spacing="4">-1</icon_placement>
            <text>
                <label>Confirm</label>
                <font name="Inter Display" size="14"/>
                <text_color>0xCCFFFFFF</text_color>
            </text>
            <active_state>
                <bg_color>0xFF0A700A</bg_color>
                <fg_color>0xFFFFFFFF</fg_color>
                <offset y="1"/>
            </active_state>
            <hilite_state>
                <bg_color>0xFF0E990E</bg_color>
                <fg_color>0xFFFFFFFF</fg_color>
            </hilite_state>
        </pushbutton_widget>
        <image_widget height="24" id="icon" left="20" top="20" width="24">
            <anchor_pos left="20" top="20"/>
            <bg_color>0x00000000</bg_color>
            <image>314</image>
        </image_widget>
        <image_widget class="P35AnimationWidget" height="24" id="anim" left="228" name="animation throbber" top="106" width="24">
            <relative_pos x="50"/>
            <visible>no</visible>
            <bg_color>0x00000000</bg_color>
            <image>287</image>
            <scale_mode>keep_aspect</scale_mode>
        </image_widget>
        <text_edit_widget class="XGTextEditWidget" height="60" id="pinc" left="140" top="118" width="200">
            <relative_pos x="50"/>
            <bg_color>0xFF141414</bg_color>
            <border_color>0xFF363636</border_color>
            <corner_radius>8</corner_radius>
            <text>
                <label>Text</label>
                <font name="Inter Display" size="24" weight="light"/>
                <align horz="center"/>
                <text_color>0xFFFFFFFF</text_color>
            </text>
            <secure>yes</secure>
            <activate_on_focus>yes</activate_on_focus>
        </text_edit_widget>
        <text_widget height="20" id="invl" left="203" top="178" width="75">
            <relative_pos x="50"/>
            <bg_color>0x00000000</bg_color>
            <text>
                <label>Invalid PIN</label>
                <font name="Helvetica" size="12"/>
                <align horz="center" vert="middle"/>
                <text_color>0xFFFF0000</text_color>
            </text>
        </text_widget>
    </panel_widget>
</xg>