{
  "files.associations": {
    ".gitignore.*": "ignore",
    ".gitmodules.*": "gitconfig"
  },
  "github-actions.workflows.pinned.workflows": [
    ".github/workflows/hostwriter.app.yml",
    ".github/workflows/publish.yml"
  ],
  "Lua.diagnostics.globals": ["spoon", "hs"],
  "vsicons.associations.files": [
    {
      "icon": "pulumi",
      "extensions": [],
      "filenamesGlob": ["Pulumi"],
      "extensionsGlob": ["yaml", "yml"],
      "filename": true,
      "format": "svg"
    }
  ]
}
