GOOGLE_APPLICATION_CREDENTIALS=.google/application_default_credentials.json
ABBR_USER_ABBREVIATIONS_FILE=~/.config/zsh/abbreviations
ZSH_COMPDUMP=~/.cache/zsh/dump
HISTFILE=~/.cache/zsh/history
HOMEBREW_NO_ENV_HINTS=true
CLOUDSDK_CONFIG=.google
KUBECONFIG=.kube/config
PNPM_HOME=~/.pnpm
PATH=${PATH}:~/.cargo/bin
PATH=${PATH}:${PNPM_HOME}
PULUMI_HOME=.pulumi
LC_COLLATE=C
CLICOLOR=1
